# LLM Provider: "hf" (HuggingFace Router API) or "ollama"
LLM_PROVIDER=hf

# Hugging Face credentials
# HF_API_KEY is required for LLM-backed answer generation when LLM_PROVIDER=hf.
HF_API_KEY=
# HF_TOKEN is used for authenticated model download/access if needed by sentence-transformers.
HF_TOKEN=

# Hugging Face Router API configuration
# HF_MODEL specifies the model to use from Hugging Face Hub.
HF_MODEL=HuggingFaceH4/zephyr-7b-beta:featherless-ai
# HF_BASE_URL is the API endpoint for Hugging Face Router.
HF_BASE_URL=https://router.huggingface.co/v1

# Ollama configuration
# OLLAMA_MODEL specifies the model to use when LLM_PROVIDER=ollama.
OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL is the API endpoint for a local Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434

# spaCy model configuration
# SPACY_MODEL can be used to specify a different spaCy model if needed.
# By default, the Docker image bakes in "en_core_web_sm".
# SPACY_MODEL=en_core_web_sm

# Input document for Docker Compose
# Filename inside the mounted ./data directory passed to the secure-rag CLI.
RAG_INPUT_FILE=sample_patient_data.txt
